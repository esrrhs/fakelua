        -:   10:// VarString是临时字符串，运行期间生成，直接从池子里切出来，最后一口气释放。
        -:   11:class VarString {
        -:   12:public:
        -:   13:    explicit VarString(const std::string_view &str) {
        -:   14:        DEBUG_ASSERT(str.size() <= static_cast<size_t>(std::numeric_limits<int>::max()));
        -:   15:        size_ = static_cast<int>(str.size());
        -:   16:        hash_ = 0;
        -:   17:        memcpy(&data_[0], str.data(), size_);
        -:   18:    }
        -:   19:
        -:   20:    // return string view
       20:   21:    [[nodiscard]] std::string_view Str() const {
       20:   22:        return {data_, static_cast<std::string_view::size_type>(size_)};
        -:   23:    }
        -:   24:
        -:   25:    [[nodiscard]] size_t Size() const {
        -:   26:        return static_cast<size_t>(size_);
        -:   27:    }
        -:   28:
        -:   29:    [[nodiscard]] uint32_t Hash() const {
        -:   30:        if (hash_ == 0) {
        -:   31:            uint32_t h = 5381;
        -:   32:            const char *p = data_;
        -:   33:            for (int i = 0; i < size_; ++i) {
        -:   34:                h = ((h << 5) + h) + static_cast<uint8_t>(p[i]);
        -:   35:            }
        -:   36:            hash_ = (h == 0) ? 1 : h;
        -:   37:        }
        -:   38:        return hash_;
        -:   39:    }
        -:   40:
        -:   41:    static VarString * AllocTemp(State *s, const std::string_view &str);
