        -:  117:
        -:  118:    [[nodiscard]] std::string ViToString(int tab) const override {
        -:  119:        std::string ret;
        -:  120:        switch (type_) {
        -:  121:            case Type::NIL:
        -:  122:                ret = "nil";
        -:  123:                break;
        -:  124:            case Type::BOOL:
        -:  125:                ret = bool_ ? "true" : "false";
        -:  126:                break;
        -:  127:            case Type::INT:
        -:  128:                ret = std::to_string(int_);
        -:  129:                break;
        -:  130:            case Type::FLOAT:
        -:  131:                ret = std::to_string(float_);
        -:  132:                break;
        -:  133:            case Type::STRING:
        -:  134:                ret = std::format("\"{}\"", string_);
        -:  135:                break;
        -:  136:            case Type::TABLE:
        -:  137:                ret = "table:";
        -:  138:                for (const auto &[fst, snd]: table_) {
        -:  139:                    ret += std::format("\n{}[{}] = {}", std::string(tab + 1, '\t'), fst->ViToString(tab + 1), snd->ViToString(tab + 1));
        -:  140:                }
        -:  141:                break;
        -:  142:        }
        -:  143:
        -:  144:        return ret;
        -:  145:    }
        -:  146:
        -:  147:    // 按键对表进行排序，仅用于调试
        -:  148:    void ViSortTable() {
        -:  149:        std::sort(table_.begin(), table_.end(), [](const auto &a, const auto &b) {
        -:  150:            if (a.first->ViGetType() != b.first->ViGetType()) {
        -:  151:                return a.first->ViGetType() < b.first->ViGetType();
        -:  152:            }
        -:  153:            switch (a.first->ViGetType()) {
        -:  154:                case Type::NIL:
        -:  155:                    return false;
        -:  156:                case Type::BOOL:
        -:  157:                    return a.first->ViGetBool() < b.first->ViGetBool();
        -:  158:                case Type::INT:
        -:  159:                    return a.first->ViGetInt() < b.first->ViGetInt();
        -:  160:                case Type::FLOAT:
        -:  161:                    return a.first->ViGetFloat() < b.first->ViGetFloat();
        -:  162:                case Type::STRING:
        -:  163:                    return a.first->ViGetString() < b.first->ViGetString();
        -:  164:                case Type::TABLE:
        -:  165:                    return a.first->ViGetTableSize() < b.first->ViGetTableSize();
        -:  166:                default:
        -:  167:                    return false;
        -:  168:            }
        -:  169:        });
        -:  170:        for (const auto &val: table_ | std::views::values) {
        -:  171:            if (val->ViGetType() == Type::TABLE) {
        -:  172:                dynamic_cast<SimpleVarImpl *>(val)->ViSortTable();
        -:  173:            }
        -:  174:        }
        -:  175:    }
