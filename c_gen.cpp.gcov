        -:  602:// 算术和比较宏（表达式风格）
        -:  603:// 为提高性能，算术运算仅支持整数和浮点类型。
        -:  604:
        -:  605:#define CheckNum(v) do { \
        -:  606:    if ((v).type_ != VAR_INT && (v).type_ != VAR_FLOAT) { \
        -:  607:        FakeluaThrowError(_S, "attempt to perform arithmetic on non-numeric value"); \
        -:  608:    } \
        -:  609:} while(0)
        -:  610:
        -:  611:#define CheckInt(v, result) do { \
        -:  612:    if ((v).type_ == VAR_INT) { (result) = (v).data_.i; } \
        -:  613:    else if ((v).type_ == VAR_FLOAT) { \
        -:  614:        double __d = (v).data_.f; \
        -:  615:        if (!isfinite(__d)) { FakeluaThrowError(_S, "number has no integer representation"); } \
        -:  616:        double __ip; \
        -:  617:        if (modf(__d, &__ip) != 0.0) { FakeluaThrowError(_S, "number has no integer representation"); } \
        -:  618:        /* 边界检查：(double)INT64_MAX 因浮点精度向上取整为 2^63，使用 '>' 而非 '>='。  */ \
        -:  619:        /* 实践中 modf 不产生恰好等于 2^63 的中间值，与 Lua 5.4 官方实现一致。          */ \
        -:  620:        if (__ip < (double)INT64_MIN || __ip > (double)INT64_MAX) { FakeluaThrowError(_S, "number has no integer representation"); } \
        -:  621:        (result) = (int64_t)__ip; \
        -:  622:    } else { \
        -:  623:        FakeluaThrowError(_S, "attempt to perform bitwise operation on non-numeric value"); \
        -:  624:        (result) = 0; \
        -:  625:    } \
        -:  626:} while(0)
        -:  627:
        -:  628:#define OpAdd(a, b, res) do { \
        -:  629:    CVar _ra = (a); CVar _rb = (b); CheckNum(_ra); CheckNum(_rb); \
        -:  630:    if (_ra.type_ == VAR_INT && _rb.type_ == VAR_INT) { SET_INT(res, _ra.data_.i + _rb.data_.i); } \
        -:  631:    else { double _f1 = (_ra.type_ == VAR_INT) ? (double)_ra.data_.i : _ra.data_.f; \
        -:  632:           double _f2 = (_rb.type_ == VAR_INT) ? (double)_rb.data_.i : _rb.data_.f; \
        -:  633:           SET_FLOAT(res, _f1 + _f2); } \
